# Konductor environment configuration
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — your secrets stay local.

# ── Server Core ──────────────────────────────────────────────────────

# Port for SSE transport (default: 3010)
KONDUCTOR_PORT=3010

# Shared API key for SSE authentication (leave empty to disable auth)
KONDUCTOR_API_KEY=change-me

# Path to YAML config file (default: ./konductor.yaml)
# KONDUCTOR_CONFIG=./konductor.yaml

# TLS/HTTPS (default: HTTPS if certs/key.pem and certs/cert.pem exist)
# Set KONDUCTOR_PROTOCOL=http to force HTTP even when certs exist
# KONDUCTOR_PROTOCOL=http
# KONDUCTOR_TLS_KEY=certs/key.pem
# KONDUCTOR_TLS_CERT=certs/cert.pem

# External URL for the server when running behind a reverse proxy or in the cloud.
# Used by the admin dashboard to generate correct install commands.
# When unset, the server uses its local hostname/port.
# KONDUCTOR_EXTERNAL_URL=https://konductor.example.com

# ── Logging ──────────────────────────────────────────────────────────

# Enable verbose logging (default: false)
VERBOSE_LOGGING=false

# Log output destinations
LOG_TO_TERMINAL=false
LOG_TO_FILE=false
LOG_FILENAME=konductor.log

# Max log file size before rotation (default: 10MB)
KONDUCTOR_LOG_MAX_SIZE=10MB

# Log level used by the server and watcher (default: info)
# Options: debug, info, warn, error
KONDUCTOR_LOG_LEVEL=info

# Alternative verbose flag (overrides VERBOSE_LOGGING when set)
# KONDUCTOR_VERBOSE=true

# ── Session & Heartbeat ──────────────────────────────────────────────

# Seconds before a session is considered stale (overrides konductor.yaml value)
# KONDUCTOR_HEARTBEAT_TIMEOUT=300

# Storage mode for session persistence (default: file)
# Options: file, memory
# KONDUCTOR_STORAGE_MODE=file

# ── Admin Dashboard ──────────────────────────────────────────────────

# Comma-separated list of admin identities (GitHub usernames or emails)
# These users get access to the admin dashboard for managing channels, settings, etc.
# KONDUCTOR_ADMINS=alice,bob@example.com

# Disable admin authentication (default: true — auth is enabled)
# Set to "false" to allow unauthenticated admin access (local dev only)
# KONDUCTOR_ADMIN_AUTH=false

# Secret for signing admin session cookies.
# If not set, a random key is generated at startup (sessions won't survive restarts).
# KONDUCTOR_SESSION_SECRET=

# Start in local mode — skips external service checks at boot (default: false)
# KONDUCTOR_STARTUP_LOCAL=true

# ── Local Bundle Store ───────────────────────────────────────────────

# Serve client installer bundles from the local ./installers/ directory.
# When true, the server scans ./installers/ for versioned .tgz files and
# makes them available for channel assignment via the admin dashboard.
# When false, falls back to packing konductor-setup/ at startup.
# KONDUCTOR_SERVE_CLIENT_BUNDLES_FROM_LOCAL_STORE=true

# ── Baton Dashboard Authentication (optional) ────────────────────────
# GitHub OAuth-based access control for the Baton dashboard.
# When BATON_GITHUB_CLIENT_ID is not set, Baton serves pages without
# authentication (open access, backward-compatible default).
#
# To enable: create a GitHub OAuth App at
#   Settings → Developer settings → OAuth Apps → New OAuth App
# Set the callback URL to: <your-server-url>/auth/callback

# GitHub OAuth App client ID (leave unset to disable Baton auth)
# BATON_GITHUB_CLIENT_ID=

# GitHub OAuth App client secret
# BATON_GITHUB_CLIENT_SECRET=

# Secret key for encrypting Baton session cookies.
# If not set, a random key is generated at startup (sessions won't survive restarts).
# BATON_SESSION_SECRET=

# Session cookie lifetime in hours (default: 8)
# BATON_SESSION_HOURS=8

# How long to cache repo access check results, in minutes (default: 5)
# BATON_ACCESS_CACHE_MINUTES=5

# ── Baton Dashboard Appearance (optional) ────────────────────────────

# Freshness indicator interval in minutes — how often the "last seen" badge
# color transitions from green → yellow → red (default: server-defined)
# BATON_FRESHNESS_INTERVAL_MINUTES=5

# Custom freshness badge colors as comma-separated hex values (green,yellow,red)
# BATON_FRESHNESS_COLORS=#22c55e,#eab308,#ef4444

# ── GitHub Integration (optional) ────────────────────────────────────
# Personal Access Token for polling PRs and commits from GitHub.
# Required scopes: repo (for private repos) or public_repo (for public repos).
# The token env var name can be overridden in konductor.yaml (tokenEnv field).
# GITHUB_TOKEN=ghp_...

# ── Slack Integration (optional) ─────────────────────────────────────
# Bot token for posting collision notifications to Slack channels.
# Obtain by installing a Slack App to your workspace (requires chat:write scope).
# When set, this env var takes precedence over the database-stored token
# configured via the Admin Dashboard.
# SLACK_BOT_TOKEN=xoxb-...

# ── Client Watcher Settings ──────────────────────────────────────────
# These are used by the konductor-watcher.mjs file watcher (client-side).
# They are read from .konductor-watcher.env in the workspace root, but
# documented here for reference.

# Poll interval in seconds for the file watcher (default: 10)
KONDUCTOR_POLL_INTERVAL=10

# File watcher log file (uncomment to enable file logging for the watcher)
# KONDUCTOR_LOG_FILE=konductor-client.log

# Restrict which file extensions the watcher tracks (comma-separated, no dots)
# When unset, all files are watched.
# KONDUCTOR_WATCH_EXTENSIONS=ts,tsx,js,jsx,py,java,go,rs,rb,json,yaml,yml,md,html,css
